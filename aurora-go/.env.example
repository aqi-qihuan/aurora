# ============================================
# Aurora Go 环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env
# ============================================

# ---------- 数据库 ----------
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_USER=aurora
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=aurora
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ---------- RabbitMQ ----------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=your_mq_password_here
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---------- Elasticsearch ----------
ES_USERNAME=
ES_PASSWORD=
ES_PORT=9200
ES_TRANSPORT_PORT=9300

# ---------- MinIO ----------
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- LLM API Keys (Agent模块) ----------
# 至少配置一个即可启用Agent功能
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
QWEN_API_KEY=your-qwen-api-key

# ---------- JWT认证 ----------
JWT_SECRET=your-jwt-secret-at-least-32-characters-long-random-string
JWT_EXPIRE_HOURS=24

# ---------- 邮箱SMTP (评论邮件通知) ----------
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-auth-code
SMTP_FROM_NAME=Aurora Blog

# ---------- 服务配置 ----------
SERVER_MODE=release
SERVER_PORT=8080
LOG_LEVEL=info

# ---------- Agent模块 (可选) ----------
AGENT_ENABLED=false
AGENT_DEFAULT_MODEL=deepseek-chat
AGENT_RAG_ENABLED=true
AGENT_AUTO_MODERATE=true
AGENT_STREAM_DEFAULT=true
AGENT_DAILY_TOKEN_LIMIT=100000
