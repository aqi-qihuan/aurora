# ============================================
# Aurora Go 环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env
#
# 环境变量映射规则 (viper):
#   AURORA_ 前缀 + 下划线分隔层级
#   例: mysql.password → AURORA_MYSQL_PASSWORD
#   例: rabbitmq.user  → AURORA_RABBITMQ_USER
#   例: es.username    → AURORA_ELASTICSEARCH_USERNAME
#
# 参考: aurora-springboot/src/main/resources/application-prod.yml
# ============================================

# ==================== 服务器配置 ====================
AURORA_SERVER_PORT=8080
AURORA_SERVER_MODE=release
AURORA_SERVER_SITE_URL=https://www.aqi125.cn

# ==================== MySQL 数据库 ====================
AURORA_MYSQL_HOST=134.175.206.158
AURORA_MYSQL_PORT=3306
AURORA_MYSQL_USER=root
AURORA_MYSQL_PASSWORD=your_mysql_password
AURORA_MYSQL_DBNAME=aurora
AURORA_MYSQL_MAX_OPEN_CONNS=20
AURORA_MYSQL_MAX_IDLE_CONNS=5
AURORA_MYSQL_MAX_LIFETIME=1800

# ==================== Redis 缓存 ====================
AURORA_REDIS_HOST=134.175.206.158
AURORA_REDIS_PORT=6379
AURORA_REDIS_PASSWORD=your_redis_password
AURORA_REDIS_DB=1
AURORA_REDIS_POOL_SIZE=100

# ==================== RabbitMQ 消息队列 ====================
AURORA_RABBITMQ_HOST=134.175.206.158
AURORA_RABBITMQ_PORT=5672
AURORA_RABBITMQ_USER=guest
AURORA_RABBITMQ_PASSWORD=your_mq_password
AURORA_RABBITMQ_VHOST=/
AURORA_RABBITMQ_PREFETCH_COUNT=10

# ==================== Elasticsearch 全文搜索 ====================
# ES URLs 在 config.yaml 中配置，此处仅设认证信息
AURORA_ELASTICSEARCH_USERNAME=elastic
AURORA_ELASTICSEARCH_PASSWORD=your_es_password

# ==================== MinIO 对象存储 ====================
# endpoint 在 config.yaml 中配置，此处仅设认证信息
AURORA_MINIO_ACCESS_KEY=your_minio_access_key
AURORA_MINIO_SECRET_KEY=your_minio_secret_key
AURORA_MINIO_BUCKET=aurora

# ==================== JWT 认证 ====================
AURORA_JWT_SECRET=your-jwt-secret-at-least-32-characters-long-random-string
AURORA_JWT_EXPIRE_TIME=168
AURORA_JWT_ISSUER=aurora-go

# ==================== QQ OAuth 登录 ====================
AURORA_QQ_APP_ID=102007196

# ==================== 搜索/上传模式 ====================
AURORA_SEARCH_MODE=elasticsearch
AURORA_UPLOAD_MODE=minio

# ==================== 邮件 SMTP (评论通知) ====================
AURORA_EMAIL_ENABLED=false
AURORA_EMAIL_HOST=smtp.qq.com
AURORA_EMAIL_PORT=465
AURORA_EMAIL_USERNAME=your_email@qq.com
AURORA_EMAIL_PASSWORD=your_smtp_auth_code
AURORA_EMAIL_FROM_NAME=Aurora Blog

# ==================== 百度 SEO 推送 ====================
AURORA_BAIDU_SEO_ENABLED=false
AURORA_BAIDU_SEO_TOKEN=your_baidu_seo_token

# ==================== 日志配置 ====================
AURORA_LOG_LEVEL=info
AURORA_LOG_FORMAT=json

# ==================== AI Agent 模块 (可选) ====================
AURORA_AGENT_ENABLED=false

# LLM API Keys (至少配置一个即可启用 Agent)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_API_KEY=
CLAUDE_API_KEY=
